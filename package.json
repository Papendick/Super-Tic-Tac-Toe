{
  "name": "super-tic-tac-toe",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build:web": "vite build",
    "build": "npm run build:web",
    "preview": "vite preview",
    "clean": "rm -rf dist android/app/build android/app/src/main/assets/public/*",
    "lint": "tsc --noEmit",
    "android:sync": "node scripts/sync-android-assets.mjs",
    "android:debug": "npm run build:web && npm run android:sync && cd android && JAVA_HOME=/root/.local/share/mise/installs/java/21.0.2 PATH=$JAVA_HOME/bin:$PATH gradle assembleDebug",
    "android:release": "npm run build:web && npm run android:sync && cd android && JAVA_HOME=/root/.local/share/mise/installs/java/21.0.2 PATH=$JAVA_HOME/bin:$PATH gradle assembleRelease"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "mitt": "^3.0.1",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
